---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import ContactForm from '../components/ContactForm.astro';
import CtaBanner from '../components/CtaBanner.astro';
import Icon from '../components/Icon.astro';
import { site, contact, social } from '../data/site';

const socialLinks = [
  { name: 'Facebook', href: social.facebook, icon: 'facebook' },
  { name: 'Instagram', href: social.instagram, icon: 'instagram' },
  { name: 'LinkedIn', href: social.linkedin, icon: 'linkedin' },
  { name: 'X (Twitter)', href: social.twitter, icon: 'twitter' },
  { name: 'YouTube', href: social.youtube, icon: 'youtube' },
];

const quickActions = [
  {
    title: 'Call us',
    detail: contact.phoneDisplay,
    href: contact.phoneHref,
    icon: 'phone',
    external: false,
  },
  {
    title: 'WhatsApp',
    detail: 'Chat with our team',
    href: contact.whatsappHref,
    icon: 'whatsapp',
    external: true,
  },
  {
    title: 'Email us',
    detail: contact.email,
    href: contact.emailHref,
    icon: 'mail',
    external: false,
  },
  {
    title: 'Get directions',
    detail: 'View on Google Maps',
    href: contact.mapUrl,
    icon: 'pin',
    external: true,
  },
];

const hours = [
  { day: 'Monday - Friday', value: '24 Hours Open' },
  { day: 'Saturday', value: '24 Hours Open' },
  { day: 'Sunday', value: '24 Hours Open' },
];

const description =
  'Contact Medilife Superspeciality Hospital in Dehradun. We are open 24/7 and committed to providing our patients with the best possible care. Call, WhatsApp, email or visit us any time.';

const contactSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: `Contact Us - ${site.name}`,
  url: new URL('/contact-us', site.url).href,
  description,
  mainEntity: {
    '@type': 'Hospital',
    name: site.name,
    telephone: contact.phoneRaw,
    email: contact.email,
    address: {
      '@type': 'PostalAddress',
      streetAddress: `${contact.addressLine1}, ${contact.addressLine2}`,
      addressLocality: contact.addressCity,
      addressRegion: contact.addressState,
      postalCode: contact.addressPostal,
      addressCountry: 'IN',
    },
    openingHours: 'Mo-Su 00:00-23:59',
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Contact Us',
      item: new URL('/contact-us', site.url).href,
    },
  ],
};
---

<BaseLayout
  title="Contact Us"
  description={description}
  jsonLd={[contactSchema, breadcrumbSchema]}
>
  <PageHero
    eyebrow="Get in Touch"
    title="Contact Us"
    subtitle="We are open 24/7. We are committed to providing our patients with the best possible care, and we invite you to reach out to learn more about our services and how we can best serve you."
    crumbs={[{ label: 'Contact Us' }]}
  />

  <!-- Quick action cards -->
  <section class="border-b border-ink-100 bg-white">
    <div class="container-x py-10">
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {quickActions.map((a) => (
          <a
            href={a.href}
            target={a.external ? '_blank' : undefined}
            rel={a.external ? 'noopener' : undefined}
            class="card card-hover group flex items-center gap-4 p-5"
          >
            <span class="grid h-12 w-12 shrink-0 place-items-center rounded-xl bg-brand-50 text-brand-600 transition group-hover:bg-brand-600 group-hover:text-white">
              <Icon name={a.icon} class="h-6 w-6" />
            </span>
            <span class="flex min-w-0 flex-col">
              <span class="font-bold text-ink-900 group-hover:text-brand-700">{a.title}</span>
              <span class="truncate text-sm text-ink-600">{a.detail}</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact details + form -->
  <section class="section">
    <div class="container-x grid items-start gap-12 lg:grid-cols-2">
      <!-- Left: details -->
      <div class="reveal">
        <span class="eyebrow">Contact Information</span>
        <h2 class="mt-4 text-3xl font-bold leading-tight text-ink-900 sm:text-4xl">
          We are here for you, day and night
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-ink-600">
          Whether you need to book an appointment, ask about a department or reach
          our emergency team, our staff is ready to help around the clock.
        </p>

        <div class="mt-8 flex flex-col gap-5">
          <a href={contact.phoneHref} class="flex items-start gap-4">
            <span class="grid h-12 w-12 shrink-0 place-items-center rounded-xl bg-brand-50 text-brand-600">
              <Icon name="phone" class="h-6 w-6" />
            </span>
            <span>
              <span class="block text-sm font-semibold text-ink-600">Phone</span>
              <span class="block text-lg font-bold text-ink-900">{contact.phoneDisplay}</span>
            </span>
          </a>

          <a href={contact.emailHref} class="flex items-start gap-4">
            <span class="grid h-12 w-12 shrink-0 place-items-center rounded-xl bg-brand-50 text-brand-600">
              <Icon name="mail" class="h-6 w-6" />
            </span>
            <span>
              <span class="block text-sm font-semibold text-ink-600">Email</span>
              <span class="block text-lg font-bold text-ink-900">{contact.email}</span>
            </span>
          </a>

          <a href={contact.mapUrl} target="_blank" rel="noopener" class="flex items-start gap-4">
            <span class="grid h-12 w-12 shrink-0 place-items-center rounded-xl bg-brand-50 text-brand-600">
              <Icon name="pin" class="h-6 w-6" />
            </span>
            <span>
              <span class="block text-sm font-semibold text-ink-600">Address</span>
              <span class="block text-base font-bold leading-snug text-ink-900">
                {contact.addressLine1}, {contact.addressLine2},<br />
                {contact.addressCity}, {contact.addressState} {contact.addressPostal}
              </span>
            </span>
          </a>

          <div class="flex items-start gap-4">
            <span class="grid h-12 w-12 shrink-0 place-items-center rounded-xl bg-brand-50 text-brand-600">
              <Icon name="clock" class="h-6 w-6" />
            </span>
            <span>
              <span class="block text-sm font-semibold text-ink-600">Hours</span>
              <span class="block text-base font-bold text-ink-900">{contact.hoursWeekday}</span>
              <span class="mt-0.5 block text-sm font-medium text-ink-600">{contact.opdHours}</span>
            </span>
          </div>
        </div>

        <!-- Opening hours card -->
        <div class="mt-8 rounded-2xl border border-ink-100 bg-ink-50/60 p-6 shadow-soft">
          <div class="flex items-center gap-2.5">
            <Icon name="heartPulse" class="h-5 w-5 text-accent-500" />
            <h3 class="text-base font-bold text-ink-900">Open 24 hours, every day</h3>
          </div>
          <dl class="mt-4 divide-y divide-ink-100">
            {hours.map((h) => (
              <div class="flex items-center justify-between py-2.5">
                <dt class="text-sm font-medium text-ink-600">{h.day}</dt>
                <dd class="inline-flex items-center gap-1.5 text-sm font-semibold text-brand-700">
                  <Icon name="check" class="h-4 w-4" /> {h.value}
                </dd>
              </div>
            ))}
          </dl>
        </div>

        <!-- Social links -->
        <div class="mt-8">
          <p class="text-sm font-semibold text-ink-600">Follow us</p>
          <div class="mt-3 flex flex-wrap gap-3">
            {socialLinks.map((s) => (
              <a
                href={s.href}
                target="_blank"
                rel="noopener"
                aria-label={s.name}
                title={s.name}
                class="grid h-11 w-11 place-items-center rounded-xl border border-ink-100 bg-white text-ink-600 shadow-soft transition hover:-translate-y-0.5 hover:border-brand-200 hover:bg-brand-600 hover:text-white"
              >
                <Icon name={s.icon} class="h-5 w-5" />
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Right: form -->
      <div class="card p-6 sm:p-8 lg:sticky lg:top-28">
        <ContactForm heading="Send us a message" />
      </div>
    </div>
  </section>

  <!-- Map -->
  <section class="section bg-ink-50/50">
    <div class="container-x">
      <span class="eyebrow">Find Us</span>
      <h2 class="mt-4 text-3xl font-bold text-ink-900">Visit Medilife in Dehradun</h2>
      <p class="mt-3 max-w-2xl text-lg text-ink-600">
        We are located at {contact.addressLine1}, {contact.addressLine2}, {contact.addressCity}.
        Convenient parking and round-the-clock access for emergencies.
      </p>
      <div class="mt-8 overflow-hidden rounded-3xl border border-ink-100 shadow-card">
        <iframe
          title="Medilife Superspeciality Hospital location map"
          src={contact.mapEmbed}
          width="100%"
          height="360"
          style="border:0; display:block;"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
      <div class="mt-6">
        <a href={contact.mapUrl} target="_blank" rel="noopener" class="btn btn-ghost">
          <Icon name="pin" class="h-5 w-5" /> Open in Google Maps
          <Icon name="arrowUpRight" class="h-4 w-4" />
        </a>
      </div>
    </div>
  </section>

  <CtaBanner />
</BaseLayout>
