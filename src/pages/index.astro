---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeHero from '../components/HomeHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import DepartmentCard from '../components/DepartmentCard.astro';
import DoctorCard from '../components/DoctorCard.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import ContactForm from '../components/ContactForm.astro';
import CtaBanner from '../components/CtaBanner.astro';
import HomeGallery from '../components/HomeGallery.astro';
import ReviewsSection from '../components/ReviewsSection.astro';
import Icon from '../components/Icon.astro';
import Img from '../components/Img.astro';
import CountUp from '../components/CountUp.astro';
import AccreditationStrip from '../components/AccreditationStrip.astro';
import { departments } from '../data/departments';
import { doctors } from '../data/doctors';
import { facilities, accreditations, whyChoose, faqs, stats } from '../data/content';
import { contact } from '../data/site';
import aboutImg from '../assets/gallery/g31.jpg';

const homeFaqs = faqs.slice(0, 6);

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: homeFaqs.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};
---

<BaseLayout jsonLd={[faqSchema]}>
  <HomeHero />

  <!-- Accreditation / trust strip -->
  <section class="border-y border-ink-100 bg-white">
    <div class="container-x py-8">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-3 lg:grid-cols-5">
        {accreditations.map((a) => (
          <div class="flex items-center gap-3">
            <span class="grid h-11 w-11 shrink-0 place-items-center rounded-xl bg-brand-50 text-brand-600">
              <Icon name={a.icon} class="h-6 w-6" />
            </span>
            <div class="leading-tight">
              <p class="text-sm font-bold text-ink-900">{a.label}</p>
              <p class="text-xs text-ink-600">{a.detail}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Specialities -->
  <section class="section bg-ink-50/50">
    <div class="container-x">
      <SectionHeading
        eyebrow="Our Specialities"
        title="Comprehensive care across every speciality"
        subtitle="From our flagship urology programme to ENT, cancer surgery, orthopedics and more - find expert, focused care for every member of your family."
      />
      <div class="reveal m-carousel mt-12 sm:grid-cols-2 sm:gap-6 lg:grid-cols-3">
        {departments.map((d) => <DepartmentCard dept={d} />)}
        <a
          href="/departments"
          class="card card-hover group flex flex-col items-center justify-center gap-3 bg-brand-700 p-8 text-center text-white"
        >
          <span class="grid h-14 w-14 place-items-center rounded-2xl bg-white/15">
            <Icon name="building" class="h-7 w-7" />
          </span>
          <h3 class="text-xl font-bold text-white">All Departments</h3>
          <p class="text-sm text-brand-50/90">Explore every speciality and facility we offer.</p>
          <span class="mt-1 inline-flex items-center gap-1.5 text-sm font-semibold">
            View all <Icon name="arrowRight" class="h-4 w-4 transition-transform group-hover:translate-x-1" />
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- Why Medilife / About preview -->
  <section class="section">
    <div class="container-x grid items-center gap-12 lg:grid-cols-2">
      <div class="reveal relative">
        <div class="overflow-hidden rounded-3xl shadow-card ring-1 ring-ink-100">
          <Img
            src={aboutImg}
            alt="Inside Medilife Superspeciality Hospital"
            width={760}
            height={560}
            class="h-full w-full object-cover"
            loading="lazy"
          />
        </div>
        <div class="absolute -bottom-6 -right-4 hidden rounded-2xl bg-white p-5 shadow-card ring-1 ring-ink-100 sm:block">
          <p class="font-display text-3xl font-extrabold text-brand-700">Care · Cure · Comfort</p>
          <p class="mt-1 text-sm text-ink-600">Our guiding philosophy</p>
        </div>
      </div>

      <div class="reveal">
        <span class="eyebrow">Why Medilife</span>
        <h2 class="mt-4 text-3xl font-bold leading-tight text-ink-900 sm:text-4xl">
          Healing with heart, excellence by design
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-ink-600">
          As an NABH-accredited multi-speciality hospital, we combine advanced medical
          technology with personalized, compassionate care to serve Dehradun and the
          wider Uttarakhand region.
        </p>
        <div class="mt-8 grid gap-5 sm:grid-cols-2">
          {whyChoose.slice(0, 4).map((w) => (
            <div class="flex gap-3">
              <span class="grid h-10 w-10 shrink-0 place-items-center rounded-xl bg-brand-50 text-brand-600">
                <Icon name={w.icon} class="h-5 w-5" />
              </span>
              <div>
                <h3 class="text-base font-bold text-ink-900">{w.title}</h3>
                <p class="mt-1 text-sm leading-relaxed text-ink-600">{w.description}</p>
              </div>
            </div>
          ))}
        </div>
        <a href="/about" class="btn btn-primary mt-8">
          More about us <Icon name="arrowRight" class="h-5 w-5" />
        </a>
      </div>
    </div>
  </section>

  <!-- Stats strip -->
  <section class="bg-gradient-to-br from-brand-700 to-brand-900">
    <div class="container-x grid grid-cols-2 gap-8 py-14 lg:grid-cols-4">
      {stats.map((s) => (
        <div class="text-center">
          <p class="font-display text-4xl font-extrabold text-white sm:text-5xl">
            <CountUp value={s.value} to={s.to} prefix={s.prefix} suffix={s.suffix} />
          </p>
          <p class="mt-2 text-sm font-medium text-brand-50/80">{s.label}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Doctors -->
  <section class="section bg-ink-50/50">
    <div class="container-x">
      <SectionHeading
        eyebrow="Meet Our Specialists"
        title="Dedication. Expertise. Passion."
        subtitle="Our team of doctors is a dedicated, expert ensemble of compassionate healers, several trained at leading institutions including AIIMS."
      />
      <div class="reveal m-carousel mt-12 sm:grid-cols-2 sm:gap-6 lg:grid-cols-4">
        {doctors.slice(0, 8).map((d) => <DoctorCard doctor={d} />)}
      </div>
      <div class="mt-8 text-center">
        <a href="/doctors" class="btn btn-ghost">
          Meet all {doctors.length} specialists <Icon name="arrowRight" class="h-5 w-5" />
        </a>
      </div>
    </div>
  </section>

  <!-- Facilities -->
  <section class="section">
    <div class="container-x">
      <SectionHeading
        eyebrow="Facilities That Care"
        title="Comprehensive support, available 24/7"
        subtitle="From emergency response and intensive care to diagnostics, pharmacy and insurance support - everything you need, under one roof."
      />
      <div class="reveal m-carousel mt-12 sm:grid-cols-2 sm:gap-6 lg:grid-cols-3">
        {facilities.map((f) => (
          <div class="card card-hover flex flex-col p-6">
            <span class="grid h-12 w-12 place-items-center rounded-xl bg-brand-50 text-brand-600">
              <Icon name={f.icon} class="h-6 w-6" />
            </span>
            <h3 class="mt-4 text-lg font-bold text-ink-900">{f.name}</h3>
            <p class="mt-2 text-[0.92rem] leading-relaxed text-ink-600">{f.description}</p>
          </div>
        ))}
      </div>
      <div class="mt-8 text-center">
        <a href="/facilities" class="btn btn-ghost">
          View all facilities <Icon name="arrowRight" class="h-5 w-5" />
        </a>
      </div>
    </div>
  </section>

  <!-- Photo gallery fold -->
  <HomeGallery />

  <!-- Patient reviews -->
  <ReviewsSection />

  <!-- FAQ -->
  <section class="section">
    <div class="container-x">
      <SectionHeading
        eyebrow="Patient FAQ"
        title="Your healthcare questions, answered"
      />
      <div class="mt-10">
        <FaqAccordion items={homeFaqs} />
        <div class="mt-8 text-center">
          <a href="/faq" class="btn btn-ghost">
            See all FAQs <Icon name="arrowRight" class="h-5 w-5" />
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="section bg-ink-50/50" id="contact">
    <div class="container-x grid gap-12 lg:grid-cols-2">
      <div>
        <span class="eyebrow">Get in Touch</span>
        <h2 class="mt-4 text-3xl font-bold leading-tight text-ink-900 sm:text-4xl">
          We’re open 24/7 - reach out any time
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-ink-600">
          We are committed to providing the best possible care. Contact us to learn more
          about our services and how we can help you and your family.
        </p>

        <div class="mt-8 flex flex-col gap-5">
          <a href={contact.phoneHref} class="flex items-start gap-4">
            <span class="grid h-12 w-12 shrink-0 place-items-center rounded-xl bg-brand-50 text-brand-600"><Icon name="phone" class="h-6 w-6" /></span>
            <span>
              <span class="block text-sm font-semibold text-ink-600">Call us</span>
              <span class="block text-lg font-bold text-ink-900">{contact.phoneDisplay}</span>
            </span>
          </a>
          <a href={contact.emailHref} class="flex items-start gap-4">
            <span class="grid h-12 w-12 shrink-0 place-items-center rounded-xl bg-brand-50 text-brand-600"><Icon name="mail" class="h-6 w-6" /></span>
            <span>
              <span class="block text-sm font-semibold text-ink-600">Email us</span>
              <span class="block text-lg font-bold text-ink-900">{contact.email}</span>
            </span>
          </a>
          <a href={contact.mapUrl} target="_blank" rel="noopener" class="flex items-start gap-4">
            <span class="grid h-12 w-12 shrink-0 place-items-center rounded-xl bg-brand-50 text-brand-600"><Icon name="pin" class="h-6 w-6" /></span>
            <span>
              <span class="block text-sm font-semibold text-ink-600">Visit us</span>
              <span class="block text-base font-bold text-ink-900">{contact.addressLine1}, {contact.addressLine2}, {contact.addressCity}</span>
            </span>
          </a>
        </div>

        <div class="mt-8 overflow-hidden rounded-2xl border border-ink-100 shadow-soft">
          <iframe
            title="Medilife Superspeciality Hospital location map"
            src={contact.mapEmbed}
            width="100%"
            height="260"
            style="border:0"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>

      <div class="card p-6 sm:p-8">
        <ContactForm heading="Request a call back" />
      </div>
    </div>
  </section>

  <AccreditationStrip />

  <CtaBanner />
</BaseLayout>
