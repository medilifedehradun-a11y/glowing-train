---
import Img from '../components/Img.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import DoctorCard from '../components/DoctorCard.astro';
import ContactForm from '../components/ContactForm.astro';
import CtaBanner from '../components/CtaBanner.astro';
import Icon from '../components/Icon.astro';
import { departments } from '../data/departments';
import { doctors } from '../data/doctors';
import { site, contact } from '../data/site';

export function getStaticPaths() {
  return departments.map((d) => ({ params: { department: d.slug }, props: { dept: d } }));
}

const { dept } = Astro.props;
const lead = doctors.find((doc) => doc.slug === dept.leadDoctor);
const others = departments.filter((d) => d.slug !== dept.slug).slice(0, 3);

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'MedicalClinic',
    name: `${dept.pageTitle} - ${site.name}`,
    url: new URL(`/${dept.slug}`, site.url).href,
    medicalSpecialty: dept.name,
    telephone: contact.phoneRaw,
    address: {
      '@type': 'PostalAddress',
      streetAddress: contact.addressLine1,
      addressLocality: contact.addressCity,
      addressRegion: contact.addressState,
      postalCode: contact.addressPostal,
      addressCountry: 'IN',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
      { '@type': 'ListItem', position: 2, name: 'Departments', item: new URL('/departments', site.url).href },
      { '@type': 'ListItem', position: 3, name: dept.name, item: new URL(`/${dept.slug}`, site.url).href },
    ],
  },
];
---

<BaseLayout
  title={dept.pageTitle}
  description={dept.metaDescription}
  jsonLd={schema}
>
  <PageHero
    eyebrow={dept.featured ? 'Flagship Department' : 'Department'}
    title={dept.pageTitle}
    subtitle={dept.tagline}
    crumbs={[{ label: 'Departments', href: '/departments' }, { label: dept.name }]}
  />

  <!-- Overview -->
  <section class="section">
    <div class="container-x grid items-start gap-12 lg:grid-cols-[1.5fr_1fr]">
      <div>
        <span class="eyebrow" style={`color:${dept.colorDark};background:${dept.bg};border-color:${dept.bg}`}>
          <Icon name={dept.icon} class="h-4 w-4" /> {dept.name}
        </span>
        <h2 class="mt-4 text-3xl font-bold text-ink-900">Expert {dept.name.toLowerCase()} care in Dehradun</h2>
        {dept.overview.map((p) => (
          <p class="mt-4 text-lg leading-relaxed text-ink-600">{p}</p>
        ))}

        <h3 class="mt-8 text-lg font-bold text-ink-900">Key focus areas</h3>
        <ul class="mt-4 grid gap-3 sm:grid-cols-2">
          {dept.highlights.map((h) => (
            <li class="flex items-start gap-2.5">
              <span class="mt-0.5 grid h-6 w-6 shrink-0 place-items-center rounded-full text-white" style={`background:${dept.color}`}>
                <Icon name="check" class="h-3.5 w-3.5" />
              </span>
              <span class="text-[0.95rem] text-ink-700">{h}</span>
            </li>
          ))}
        </ul>
      </div>

      <aside class="flex flex-col gap-6">
        <div class="overflow-hidden rounded-3xl shadow-card ring-1 ring-ink-100">
          <Img
            src={dept.image}
            alt={`${dept.name} department at ${site.name}`}
            width={560}
            height={400}
            class="h-56 w-full object-cover"
            loading="eager"
          />
        </div>
        <div class="rounded-3xl p-6 text-white shadow-card" style={`background:${dept.colorDark}`}>
          <h3 class="text-lg font-bold text-white">Book a consultation</h3>
          <p class="mt-2 text-sm text-white/85">Speak with our {dept.name.toLowerCase()} specialists. We are available 24/7 for emergencies.</p>
          <div class="mt-5 flex flex-col gap-2.5">
            <a href="/book-online" class="btn btn-white w-full">
              <Icon name="calendar" class="h-5 w-5" /> Book Appointment
            </a>
            <a href={contact.phoneHref} class="inline-flex items-center justify-center gap-2 rounded-xl border border-white/30 px-4 py-3 text-sm font-semibold text-white transition hover:bg-white/10">
              <Icon name="phone" class="h-4 w-4" /> {contact.phoneDisplay}
            </a>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <!-- Procedures -->
  <section class="section bg-ink-50/50">
    <div class="container-x">
      <span class="eyebrow">Treatments & Procedures</span>
      <h2 class="mt-4 text-3xl font-bold text-ink-900">What we offer</h2>
      <p class="mt-3 max-w-2xl text-lg text-ink-600">
        Our {dept.name.toLowerCase()} department provides a comprehensive range of diagnostic and surgical procedures.
      </p>
      <div class="mt-10 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {dept.procedures.map((p) => (
          <div class="flex items-center gap-3 rounded-xl border border-ink-100 bg-white p-4 shadow-soft transition hover:border-brand-200 hover:shadow-card">
            <span class="grid h-9 w-9 shrink-0 place-items-center rounded-lg" style={`background:${dept.bg};color:${dept.colorDark}`}>
              <Icon name="check" class="h-5 w-5" />
            </span>
            <span class="text-[0.92rem] font-medium text-ink-800">{p}</span>
          </div>
        ))}
      </div>

      {dept.conditions && dept.conditions.length > 0 && (
        <div class="mt-12 rounded-3xl border border-ink-100 bg-white p-8 shadow-soft">
          <h3 class="text-xl font-bold text-ink-900">Conditions we treat</h3>
          <div class="mt-5 flex flex-wrap gap-2.5">
            {dept.conditions.map((c) => (
              <span class="rounded-full bg-brand-50 px-4 py-2 text-sm font-medium text-brand-800">{c}</span>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- Lead doctor -->
  {lead && (
    <section class="section">
      <div class="container-x">
        <span class="eyebrow">Your Specialist</span>
        <h2 class="mt-4 text-3xl font-bold text-ink-900">Meet the consultant</h2>
        <div class="mt-8 grid gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-center">
          <div class="max-w-sm">
            <DoctorCard doctor={lead} />
          </div>
          <div>
            <h3 class="text-2xl font-bold text-ink-900">{lead.name}</h3>
            <p class="mt-1 font-semibold text-brand-700">{lead.title}</p>
            <p class="mt-4 text-lg leading-relaxed text-ink-600">{lead.bio}</p>
            <a href="/book-online" class="btn btn-primary mt-6">
              <Icon name="calendar" class="h-5 w-5" /> Book with {lead.name.split(' ').slice(0, 2).join(' ')}
            </a>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Related departments -->
  <section class="section bg-ink-50/50">
    <div class="container-x">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
          <span class="eyebrow">Explore More</span>
          <h2 class="mt-4 text-3xl font-bold text-ink-900">Other departments</h2>
        </div>
        <a href="/departments" class="btn btn-ghost">All departments <Icon name="arrowRight" class="h-5 w-5" /></a>
      </div>
      <div class="mt-10 grid gap-6 sm:grid-cols-3">
        {others.map((d) => (
          <a href={`/${d.slug}`} class="card card-hover group flex items-center gap-4 p-5">
            <span class="grid h-12 w-12 shrink-0 place-items-center rounded-xl text-white" style={`background:${d.color}`}>
              <Icon name={d.icon} class="h-6 w-6" />
            </span>
            <span class="flex flex-col">
              <span class="font-bold text-ink-900 group-hover:text-brand-700">{d.name}</span>
              <span class="text-sm text-ink-600">{d.tagline}</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Enquiry -->
  <section class="section">
    <div class="container-x grid gap-12 lg:grid-cols-2">
      <div>
        <span class="eyebrow">Enquire Now</span>
        <h2 class="mt-4 text-3xl font-bold text-ink-900">Have a question about {dept.name.toLowerCase()}?</h2>
        <p class="mt-4 text-lg leading-relaxed text-ink-600">
          Send us your details and our team will get back to you. For urgent help, call us any time.
        </p>
        <div class="mt-8 flex flex-col gap-4">
          <a href={contact.phoneHref} class="flex items-center gap-4">
            <span class="grid h-12 w-12 place-items-center rounded-xl bg-brand-50 text-brand-600"><Icon name="phone" class="h-6 w-6" /></span>
            <span><span class="block text-sm font-semibold text-ink-600">Call</span><span class="text-lg font-bold text-ink-900">{contact.phoneDisplay}</span></span>
          </a>
          <a href={contact.emailHref} class="flex items-center gap-4">
            <span class="grid h-12 w-12 place-items-center rounded-xl bg-brand-50 text-brand-600"><Icon name="mail" class="h-6 w-6" /></span>
            <span><span class="block text-sm font-semibold text-ink-600">Email</span><span class="text-lg font-bold text-ink-900">{contact.email}</span></span>
          </a>
        </div>
      </div>
      <div class="card p-6 sm:p-8">
        <ContactForm heading="Request a call back" department={dept.slug} />
      </div>
    </div>
  </section>

  <CtaBanner />
</BaseLayout>
