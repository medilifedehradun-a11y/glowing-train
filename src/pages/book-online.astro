---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import ContactForm from '../components/ContactForm.astro';
import CtaBanner from '../components/CtaBanner.astro';
import Icon from '../components/Icon.astro';
import { departments } from '../data/departments';
import { site, contact } from '../data/site';

const steps = [
  {
    icon: 'calendar',
    title: 'Send your request',
    description:
      'Fill in the form with your name, contact details and the department you need. Add a short note about your concern if you like.',
  },
  {
    icon: 'phone',
    title: 'We confirm by call',
    description:
      'Our front-desk team reviews your request and calls you back to confirm a convenient date and time with the right specialist.',
  },
  {
    icon: 'stethoscope',
    title: 'Visit & consult',
    description:
      'Arrive a little before your slot, complete a quick registration and meet your consultant for a focused, unhurried consultation.',
  },
];

const bringItems = [
  {
    icon: 'user',
    title: 'A valid photo ID',
    description: 'Aadhaar, driving licence or any government-issued identity card.',
  },
  {
    icon: 'microscope',
    title: 'Previous medical reports',
    description: 'Past prescriptions, lab results, X-rays, scans and discharge summaries.',
  },
  {
    icon: 'shield',
    title: 'Insurance or Ayushman card',
    description: 'Your insurance, TPA or Ayushman Bharat (PM-JAY) card for cashless support.',
  },
];

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Book an Appointment',
        item: new URL('/book-online', site.url).href,
      },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ContactPage',
    name: `Book an Appointment - ${site.name}`,
    url: new URL('/book-online', site.url).href,
    description:
      'Request a consultation with the specialists at Medilife Superspeciality Hospital, Dehradun. We will confirm your appointment shortly.',
  },
];
---

<BaseLayout
  title="Book an Appointment"
  description="Request a consultation with the specialists at Medilife Superspeciality Hospital, Dehradun. Choose a department, share your details and our team will confirm your appointment shortly."
  jsonLd={schema}
>
  <PageHero
    eyebrow="Appointments"
    title="Book an Appointment"
    subtitle="Request a consultation with our specialists - we will confirm shortly."
    crumbs={[{ label: 'Book an Appointment' }]}
  />

  <!-- Booking: info panel + form -->
  <section class="section">
    <div class="container-x grid items-start gap-12 lg:grid-cols-[1.1fr_1fr]">
      <!-- LEFT: info panel -->
      <div class="reveal flex flex-col gap-12">
        <!-- How it works -->
        <div>
          <span class="eyebrow">How It Works</span>
          <h2 class="mt-4 text-3xl font-bold text-ink-900">Three simple steps to your visit</h2>
          <p class="mt-3 text-lg leading-relaxed text-ink-600">
            Booking with Medilife is quick and personal. Tell us what you need and our team
            takes care of the rest.
          </p>
          <ol class="mt-8 flex flex-col gap-5">
            {steps.map((s, i) => (
              <li class="flex gap-4">
                <span class="relative grid h-12 w-12 shrink-0 place-items-center rounded-2xl bg-brand-50 text-brand-600">
                  <Icon name={s.icon} class="h-6 w-6" />
                  <span class="absolute -right-1.5 -top-1.5 grid h-6 w-6 place-items-center rounded-full bg-brand-700 text-xs font-bold text-white">
                    {i + 1}
                  </span>
                </span>
                <div>
                  <h3 class="text-base font-bold text-ink-900">{s.title}</h3>
                  <p class="mt-1 text-[0.95rem] leading-relaxed text-ink-600">{s.description}</p>
                </div>
              </li>
            ))}
          </ol>
        </div>

        <!-- What to bring -->
        <div>
          <span class="eyebrow">Come Prepared</span>
          <h2 class="mt-4 text-2xl font-bold text-ink-900">What to bring</h2>
          <div class="mt-6 grid gap-4 sm:grid-cols-3">
            {bringItems.map((b) => (
              <div class="card flex flex-col p-5">
                <span class="grid h-11 w-11 place-items-center rounded-xl bg-brand-50 text-brand-600">
                  <Icon name={b.icon} class="h-6 w-6" />
                </span>
                <h3 class="mt-3 text-sm font-bold text-ink-900">{b.title}</h3>
                <p class="mt-1.5 text-[0.85rem] leading-relaxed text-ink-600">{b.description}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Hours -->
        <div class="grid gap-5 sm:grid-cols-2">
          <div class="rounded-3xl border border-ink-100 bg-white p-6 shadow-soft">
            <span class="grid h-11 w-11 place-items-center rounded-xl bg-brand-50 text-brand-600">
              <Icon name="clock" class="h-6 w-6" />
            </span>
            <h3 class="mt-4 text-base font-bold text-ink-900">OPD hours</h3>
            <p class="mt-1 text-[0.95rem] font-semibold text-brand-700">{contact.opdHours}</p>
            <p class="mt-1 text-sm text-ink-600">Monday to Sunday, walk-ins welcome.</p>
          </div>
          <div class="rounded-3xl bg-gradient-to-br from-brand-700 to-brand-900 p-6 text-white shadow-card">
            <span class="grid h-11 w-11 place-items-center rounded-xl bg-white/15">
              <Icon name="ambulance" class="h-6 w-6" />
            </span>
            <h3 class="mt-4 text-base font-bold text-white">Emergency care</h3>
            <p class="mt-1 text-[0.95rem] font-semibold text-brand-50">Open 24/7, every day</p>
            <p class="mt-1 text-sm text-brand-50/80">
              No appointment needed for emergencies, just come straight in.
            </p>
          </div>
        </div>

        <!-- Choose a department -->
        <div>
          <span class="eyebrow">Choose a Department</span>
          <h2 class="mt-4 text-2xl font-bold text-ink-900">Which specialist do you need?</h2>
          <p class="mt-3 text-[0.95rem] leading-relaxed text-ink-600">
            Select the right speciality in the form, or explore our departments below to find
            the best fit for your concern.
          </p>
          <ul class="mt-6 grid gap-3 sm:grid-cols-2">
            {departments.map((d) => (
              <li>
                <a
                  href={`/${d.slug}`}
                  class="group flex items-center gap-3 rounded-xl border border-ink-100 bg-white p-3.5 shadow-soft transition hover:border-brand-200 hover:shadow-card"
                >
                  <span
                    class="grid h-10 w-10 shrink-0 place-items-center rounded-lg text-white"
                    style={`background:${d.color}`}
                  >
                    <Icon name={d.icon} class="h-5 w-5" />
                  </span>
                  <span class="flex min-w-0 flex-col">
                    <span class="truncate text-sm font-bold text-ink-900 group-hover:text-brand-700">
                      {d.name}
                    </span>
                    <span class="truncate text-xs text-ink-600">{d.tagline}</span>
                  </span>
                  <Icon
                    name="arrowRight"
                    class="ml-auto h-4 w-4 shrink-0 text-ink-300 transition-transform group-hover:translate-x-1 group-hover:text-brand-600"
                  />
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Quick contact -->
        <div class="rounded-3xl border border-ink-100 bg-ink-50/60 p-6">
          <h3 class="text-base font-bold text-ink-900">Prefer to reach us directly?</h3>
          <div class="mt-5 flex flex-col gap-4 sm:flex-row sm:gap-8">
            <a href={contact.phoneHref} class="flex items-center gap-3">
              <span class="grid h-11 w-11 shrink-0 place-items-center rounded-xl bg-brand-50 text-brand-600">
                <Icon name="phone" class="h-5 w-5" />
              </span>
              <span>
                <span class="block text-xs font-semibold uppercase tracking-wide text-ink-600">Call us</span>
                <span class="block font-bold text-ink-900">{contact.phoneDisplay}</span>
              </span>
            </a>
            <a href={contact.emailHref} class="flex items-center gap-3">
              <span class="grid h-11 w-11 shrink-0 place-items-center rounded-xl bg-brand-50 text-brand-600">
                <Icon name="mail" class="h-5 w-5" />
              </span>
              <span>
                <span class="block text-xs font-semibold uppercase tracking-wide text-ink-600">Email us</span>
                <span class="block font-bold text-ink-900">{contact.email}</span>
              </span>
            </a>
          </div>
        </div>
      </div>

      <!-- RIGHT: form -->
      <div class="lg:sticky lg:top-28">
        <div class="card p-6 shadow-card sm:p-8">
          <p class="eyebrow">Request a Slot</p>
          <ContactForm heading="Appointment request" class="mt-4" />
        </div>
      </div>
    </div>
  </section>

  <!-- Emergency callout band -->
  <section class="bg-accent-600">
    <div class="container-x py-10">
      <div class="flex flex-col items-center gap-6 text-center sm:flex-row sm:justify-between sm:text-left">
        <div class="flex items-center gap-4">
          <span class="grid h-14 w-14 shrink-0 place-items-center rounded-2xl bg-white/15 text-white">
            <Icon name="ambulance" class="h-7 w-7" />
          </span>
          <div>
            <h2 class="text-xl font-bold text-white sm:text-2xl">Medical emergency? Do not wait.</h2>
            <p class="mt-1 text-accent-50/90">
              Our emergency team and ambulance are available 24/7. Call us right now for urgent care.
            </p>
          </div>
        </div>
        <a href={contact.emergencyHref} class="btn btn-white shrink-0 whitespace-nowrap">
          <Icon name="phone" class="h-5 w-5" /> {contact.emergencyDisplay}
        </a>
      </div>
    </div>
  </section>

  <CtaBanner />
</BaseLayout>
