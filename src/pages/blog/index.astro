---
import Img from '../../components/Img.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import Icon from '../../components/Icon.astro';
import { posts } from '../../data/blog';
import { site } from '../../data/site';

// Newest first.
const sorted = [...posts].sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()
);

const categories = ['All Posts', ...Array.from(new Set(posts.map((p) => p.category)))];

const fmtDate = (iso: string) =>
  new Date(iso).toLocaleDateString('en-IN', {
    day: 'numeric',
    month: 'short',
    year: 'numeric',
  });

const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: `${site.name} Health Blog`,
  url: new URL('/blog', site.url).href,
  description:
    'Health tips, hospital news and wellness insights from the specialists at Medilife Superspeciality Hospital, Dehradun.',
  blogPost: sorted.map((p) => ({
    '@type': 'BlogPosting',
    headline: p.title,
    datePublished: p.date,
    author: { '@type': 'Organization', name: p.author },
    url: new URL(`/blog/${p.slug}`, site.url).href,
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: new URL('/blog', site.url).href },
  ],
};
---

<BaseLayout
  title="Health Blog"
  description="Health tips, hospital news and wellness insights from the specialists at Medilife Superspeciality Hospital, Dehradun. Your partner in health and wellness."
  jsonLd={[blogSchema, breadcrumbSchema]}
>
  <PageHero
    eyebrow="Insights & Updates"
    title="Health Blog"
    subtitle="Health tips, the latest medical advancements and stories from our team. We believe knowledge is power on every patient's healthcare journey."
    crumbs={[{ label: 'Blog' }]}
  />

  <!-- Posts -->
  <section class="section">
    <div class="container-x">
      <!-- Topic tags (informational labels) -->
      <ul class="flex flex-wrap items-center gap-2.5">
        {categories.map((c) => (
          <li class="rounded-full bg-ink-50 px-4 py-2 text-sm font-semibold text-ink-600 ring-1 ring-ink-100">
            {c}
          </li>
        ))}
      </ul>

      <div class="reveal mt-10 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {sorted.map((post) => (
          <article class="card card-hover group flex flex-col overflow-hidden">
            <a href={`/blog/${post.slug}`} class="block overflow-hidden" aria-label={post.title}>
              <Img
                src={post.image}
                alt={post.imageAlt}
                width={640}
                height={400}
                class="h-52 w-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
                loading="lazy"
              />
            </a>
            <div class="flex flex-1 flex-col p-6">
              <div class="flex flex-wrap items-center gap-3 text-xs font-medium text-ink-600">
                <span class="rounded-full bg-brand-50 px-3 py-1 font-semibold text-brand-700">
                  {post.category}
                </span>
                <span class="inline-flex items-center gap-1.5">
                  <Icon name="calendar" class="h-3.5 w-3.5" />
                  <time datetime={post.date}>{fmtDate(post.date)}</time>
                </span>
                <span class="inline-flex items-center gap-1.5">
                  <Icon name="clock" class="h-3.5 w-3.5" /> {post.readingTime}
                </span>
              </div>
              <h2 class="mt-4 text-xl font-bold leading-snug text-ink-900 transition-colors group-hover:text-brand-700">
                <a href={`/blog/${post.slug}`}>{post.title}</a>
              </h2>
              <p class="mt-3 text-[0.95rem] leading-relaxed text-ink-600">{post.excerpt}</p>
              <a
                href={`/blog/${post.slug}`}
                class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-brand-700"
              >
                Read more
                <Icon name="arrowRight" class="h-4 w-4 transition-transform group-hover:translate-x-1" />
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CtaBanner />
</BaseLayout>
