---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ContactForm from '../components/ContactForm.astro';
import CtaBanner from '../components/CtaBanner.astro';
import Icon from '../components/Icon.astro';
import { departments } from '../data/departments';
import { facilities } from '../data/content';
import { site, contact } from '../data/site';

// Three signature hospital-experience tiles (faithful to the live "Our Services" page).
const heroTiles = [
  {
    eyebrow: 'Nursing Service',
    title: 'A Happier, Healthier You',
    text: 'Compassionate, round-the-clock nursing care that puts your comfort, dignity and recovery first - at every step of your stay.',
    icon: 'heartPulse',
  },
  {
    eyebrow: 'Accommodation',
    title: 'Here For You',
    text: 'Clean, comfortable and well-equipped rooms designed to help patients and their families rest, heal and feel at home.',
    icon: 'bed',
  },
  {
    eyebrow: 'Laboratory & Diagnostics',
    title: 'Quality Care',
    text: 'NABL-accredited pathology and diagnostic procedures delivering accurate, timely results to guide confident clinical decisions.',
    icon: 'microscope',
  },
];

// Support services drawn from the shared facilities data (24/7 backbone of every service).
const supportNames = ['Pharmacy', 'Pathology', 'Ambulance', 'Insurance & TPA'];
const supportServices = supportNames
  .map((n) => facilities.find((f) => f.name === n))
  .filter((f): f is NonNullable<typeof f> => Boolean(f));

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Services', item: new URL('/services', site.url).href },
  ],
};
---

<BaseLayout
  title="Our Services"
  description="Explore the full range of services at Medilife Superspeciality Hospital, Dehradun - nursing care, in-patient accommodation, laboratory and diagnostics, seven clinical superspecialities and 24x7 pharmacy, pathology, ambulance and insurance support."
  jsonLd={[breadcrumbSchema]}
>
  <PageHero
    eyebrow="What We Offer"
    title="Our Services"
    subtitle="From dedicated nursing and comfortable accommodation to advanced diagnostics and seven clinical superspecialities - complete, compassionate care under one roof."
    crumbs={[{ label: 'Services' }]}
  />

  <!-- Section 1: Signature experience tiles -->
  <section class="section">
    <div class="container-x">
      <SectionHeading
        eyebrow="The Medilife Experience"
        title="Care that surrounds every patient"
        subtitle="Beyond treatment, we look after the everyday details that help you and your family feel supported, comfortable and confident throughout your journey with us."
      />
      <div class="reveal mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {heroTiles.map((tile) => (
          <article class="card card-hover flex flex-col p-7">
            <span class="grid h-14 w-14 place-items-center rounded-2xl bg-brand-50 text-brand-600">
              <Icon name={tile.icon} class="h-7 w-7" />
            </span>
            <span class="mt-5 text-xs font-bold uppercase tracking-wider text-brand-600">{tile.eyebrow}</span>
            <h3 class="mt-1 text-xl font-bold text-ink-900">{tile.title}</h3>
            <p class="mt-2 flex-1 text-[0.93rem] leading-relaxed text-ink-600">{tile.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 2: Clinical superspecialities -->
  <section class="section bg-ink-50/50">
    <div class="container-x">
      <SectionHeading
        eyebrow="Our Specialities"
        title="Specialist care, one trusted team"
        subtitle="Each department is led by experienced specialists using modern technology and minimally invasive techniques - explore the focused care available for every member of your family."
      />
      <div class="reveal m-carousel mt-12 sm:grid-cols-2 sm:gap-6 lg:grid-cols-3">
        {departments.map((d) => (
          <a
            href={`/${d.slug}`}
            class="card card-hover group relative flex flex-col p-6"
          >
            {d.featured && (
              <span class="absolute right-4 top-4 rounded-full bg-accent-500 px-2.5 py-1 text-[0.68rem] font-bold uppercase tracking-wide text-white shadow">
                Flagship
              </span>
            )}
            <span
              class="grid h-14 w-14 place-items-center rounded-2xl text-white shadow-sm"
              style={`background:${d.color}`}
            >
              <Icon name={d.icon} class="h-7 w-7" />
            </span>
            <h3 class="mt-5 text-xl font-bold text-ink-900 transition group-hover:text-brand-700">
              {d.name}
            </h3>
            <p class="mt-2 flex-1 text-[0.93rem] leading-relaxed text-ink-600">{d.excerpt}</p>
            <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-brand-700">
              Learn more
              <Icon name="arrowRight" class="h-4 w-4 transition-transform group-hover:translate-x-1" />
            </span>
          </a>
        ))}
        <a
          href="/departments"
          class="card card-hover group flex flex-col items-center justify-center gap-3 bg-brand-700 p-8 text-center text-white"
        >
          <span class="grid h-14 w-14 place-items-center rounded-2xl bg-white/15">
            <Icon name="building" class="h-7 w-7" />
          </span>
          <h3 class="text-xl font-bold text-white">All Departments</h3>
          <p class="text-sm text-brand-50/90">See every speciality, procedure and specialist we offer.</p>
          <span class="mt-1 inline-flex items-center gap-1.5 text-sm font-semibold">
            View all <Icon name="arrowRight" class="h-4 w-4 transition-transform group-hover:translate-x-1" />
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- Section 3: 24x7 support services -->
  <section class="section">
    <div class="container-x">
      <SectionHeading
        eyebrow="Support Services"
        title="The 24x7 backbone of every treatment"
        subtitle="Genuine medicines, accurate diagnostics, rapid transport and cashless paperwork - everything that surrounds your care, available whenever you need it."
      />
      <div class="reveal mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {supportServices.map((f) => (
          <div class="card card-hover flex flex-col p-6">
            <span class="grid h-12 w-12 place-items-center rounded-xl bg-brand-50 text-brand-600">
              <Icon name={f.icon} class="h-6 w-6" />
            </span>
            <h3 class="mt-4 text-lg font-bold text-ink-900">{f.name}</h3>
            <p class="mt-2 text-[0.92rem] leading-relaxed text-ink-600">{f.description}</p>
          </div>
        ))}
      </div>

      <div class="mt-10 grid gap-4 rounded-3xl border border-ink-100 bg-ink-50/60 p-6 shadow-soft sm:grid-cols-3 sm:p-8">
        <div class="flex items-center gap-3">
          <span class="grid h-11 w-11 shrink-0 place-items-center rounded-xl bg-brand-50 text-brand-600"><Icon name="clock" class="h-6 w-6" /></span>
          <div class="leading-tight">
            <p class="text-sm font-bold text-ink-900">{contact.hoursWeekday}</p>
            <p class="text-xs text-ink-600">{contact.opdHours}</p>
          </div>
        </div>
        <a href={contact.phoneHref} class="flex items-center gap-3">
          <span class="grid h-11 w-11 shrink-0 place-items-center rounded-xl bg-brand-50 text-brand-600"><Icon name="phone" class="h-6 w-6" /></span>
          <div class="leading-tight">
            <p class="text-sm font-bold text-ink-900">{contact.phoneDisplay}</p>
            <p class="text-xs text-ink-600">Emergency & appointments</p>
          </div>
        </a>
        <a href={contact.emailHref} class="flex items-center gap-3">
          <span class="grid h-11 w-11 shrink-0 place-items-center rounded-xl bg-brand-50 text-brand-600"><Icon name="mail" class="h-6 w-6" /></span>
          <div class="leading-tight">
            <p class="text-sm font-bold text-ink-900">{contact.email}</p>
            <p class="text-xs text-ink-600">Email our care team</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Enquiry -->
  <section class="section bg-ink-50/50" id="enquire">
    <div class="container-x grid gap-12 lg:grid-cols-2">
      <div>
        <span class="eyebrow">Enquire Now</span>
        <h2 class="mt-4 text-3xl font-bold leading-tight text-ink-900 sm:text-4xl">
          Not sure which service you need?
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-ink-600">
          Tell us a little about your concern and our team will guide you to the right
          department and specialist. For urgent help, we are available around the clock.
        </p>
        <div class="mt-8 grid gap-5 sm:grid-cols-2">
          {[
            { icon: 'stethoscope', title: 'Expert specialists', text: 'Several with 30+ years of experience, trained at leading institutions including AIIMS.' },
            { icon: 'shield', title: 'NABH accredited', text: 'Quality-assured care with all major insurance, TPA and Ayushman Bharat accepted.' },
            { icon: 'ambulance', title: '24x7 emergency', text: 'Round-the-clock emergency, ICU and ambulance response when every second counts.' },
            { icon: 'flask', title: 'NABL diagnostics', text: 'Accurate, in-house pathology and diagnostics for faster, confident treatment.' },
          ].map((item) => (
            <div class="flex gap-3">
              <span class="grid h-10 w-10 shrink-0 place-items-center rounded-xl bg-brand-50 text-brand-600">
                <Icon name={item.icon} class="h-5 w-5" />
              </span>
              <div>
                <h3 class="text-base font-bold text-ink-900">{item.title}</h3>
                <p class="mt-1 text-sm leading-relaxed text-ink-600">{item.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
      <div class="card p-6 sm:p-8">
        <ContactForm heading="Request a call back" />
      </div>
    </div>
  </section>

  <CtaBanner />
</BaseLayout>
