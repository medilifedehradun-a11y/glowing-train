---
import Img from './Img.astro';
import Icon from './Icon.astro';
import type { Department } from '../data/departments';

interface Props {
  dept: Department;
  class?: string;
}
const { dept, class: className = '' } = Astro.props;
---

<a
  href={`/${dept.slug}`}
  class:list={[
    'card card-hover group relative flex flex-col overflow-hidden',
    className,
  ]}
>
  {dept.featured && (
    <span class="absolute right-4 top-4 z-10 rounded-full bg-accent-500 px-2.5 py-1 text-[0.68rem] font-bold uppercase tracking-wide text-white shadow">
      Flagship
    </span>
  )}
  <div class="relative aspect-[16/10] overflow-hidden bg-ink-50">
    <Img
      src={dept.image}
      alt={`${dept.name} department at Medilife`}
      width={560}
      height={350}
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
      loading="lazy"
    />
    <span
      class="absolute bottom-0 left-0 m-4 grid h-12 w-12 place-items-center rounded-xl text-white shadow-lg"
      style={`background:${dept.color}`}
    >
      <Icon name={dept.icon} class="h-6 w-6" />
    </span>
  </div>
  <div class="flex flex-1 flex-col p-6">
    <h3 class="text-xl font-bold text-ink-900 transition group-hover:text-brand-700">
      {dept.name}
    </h3>
    <p class="mt-2 flex-1 text-[0.93rem] leading-relaxed text-ink-600">
      {dept.excerpt}
    </p>
    <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-brand-700">
      Learn more
      <Icon name="arrowRight" class="h-4 w-4 transition-transform group-hover:translate-x-1" />
    </span>
  </div>
</a>
