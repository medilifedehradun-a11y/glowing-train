---
import Icon from './Icon.astro';
import { contact } from '../data/site';

interface Props {
  title?: string;
  text?: string;
}
const {
  title = 'Need medical help? We are here 24×7.',
  text = 'Book an appointment with our specialists or reach our emergency team any time, day or night.',
} = Astro.props;
---

<section class="section">
  <div class="container-x">
    <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-brand-700 via-brand-700 to-brand-900 px-6 py-12 text-center shadow-lift sm:px-12 sm:py-16">
      <div class="pointer-events-none absolute -right-16 -top-16 h-64 w-64 rounded-full bg-white/5"></div>
      <div class="pointer-events-none absolute -bottom-20 -left-10 h-72 w-72 rounded-full bg-white/5"></div>
      <div class="relative mx-auto max-w-2xl">
        <h2 class="text-3xl font-bold text-white sm:text-4xl">{title}</h2>
        <p class="mt-4 text-lg text-brand-50/90">{text}</p>
        <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a href="/book-online" class="btn btn-accent w-full sm:w-auto">
            <Icon name="calendar" class="h-5 w-5" /> Book an Appointment
          </a>
          <a href={contact.phoneHref} class="btn btn-white w-full sm:w-auto">
            <Icon name="phone" class="h-5 w-5" /> {contact.phoneDisplay}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
