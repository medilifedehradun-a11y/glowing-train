---
import Img from './Img.astro';
import Icon from './Icon.astro';
import type { Doctor } from '../data/doctors';

interface Props {
  doctor: Doctor;
  class?: string;
}
const { doctor, class: className = '' } = Astro.props;
---

<article class:list={['card card-hover group flex flex-col overflow-hidden', className]}>
  <div class="relative aspect-[4/3] overflow-hidden bg-brand-50">
    <Img
      src={doctor.image}
      alt={`Portrait of ${doctor.name}`}
      width={440}
      height={330}
      class="h-full w-full object-cover object-top transition-transform duration-500 group-hover:scale-105"
      loading="lazy"
    />
    <span class="absolute left-3 top-3 rounded-full bg-white/95 px-2.5 py-1 text-[0.68rem] font-bold uppercase tracking-wide text-brand-700 shadow-sm backdrop-blur">
      {doctor.specialtyTag}
    </span>
  </div>
  <div class="flex flex-1 flex-col p-5">
    <h3 class="text-lg font-bold text-ink-900">{doctor.name}</h3>
    <p class="mt-0.5 text-[0.85rem] font-semibold text-brand-700">{doctor.title}</p>
    <p class="mt-3 flex-1 text-[0.86rem] leading-relaxed text-ink-600">{doctor.bio}</p>
    <div class="mt-4 flex items-center justify-between border-t border-ink-100 pt-4">
      <a
        href={`/${doctor.department}`}
        class="inline-flex items-center gap-1 text-[0.82rem] font-semibold text-brand-700 transition hover:gap-2"
      >
        View department <Icon name="arrowRight" class="h-3.5 w-3.5" />
      </a>
      {doctor.linkedin && (
        <a
          href={doctor.linkedin}
          target="_blank"
          rel="noopener"
          aria-label={`${doctor.name} on LinkedIn`}
          class="-mr-2 grid h-10 w-10 place-items-center rounded-lg text-ink-600 transition hover:bg-brand-50 hover:text-brand-600"
        >
          <Icon name="linkedin" class="h-4 w-4" />
        </a>
      )}
    </div>
  </div>
</article>
