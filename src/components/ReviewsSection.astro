---
import Icon from './Icon.astro';
import SectionHeading from './SectionHeading.astro';
import { testimonials } from '../data/content';
import { contact, integrations } from '../data/site';

interface Props {
  /** dark gradient or light background */
  variant?: 'light' | 'dark';
}
const { variant = 'light' } = Astro.props;
const dark = variant === 'dark';
const widget = integrations.reviewsWidgetEmbed?.trim();
const reExecScript =
  `document.addEventListener('astro:page-load',function(){document.querySelectorAll('.reviews-embed script').forEach(function(old){if(old.dataset.ran)return;var s=document.createElement('script');for(var i=0;i<old.attributes.length;i++){s.setAttribute(old.attributes[i].name,old.attributes[i].value);}s.textContent=old.textContent;old.dataset.ran='true';old.parentNode.replaceChild(s,old);});});`;
---

<section class:list={['section', dark ? 'bg-brand-800' : 'bg-ink-50/50']}>
  <div class="container-x">
    <SectionHeading
      eyebrow="Patient Reviews"
      title="Trusted by patients across Dehradun"
      subtitle="Real experiences from the people we care for. Read our reviews on Google, or share your own."
      light={dark}
    />

    {widget ? (
      <div class="reviews-embed mt-12" set:html={widget} />
    ) : (
      <div class="mt-12 grid gap-6 lg:grid-cols-[1.1fr_1.4fr] lg:items-stretch">
        <!-- Google reviews card -->
        <div class="flex flex-col justify-between rounded-3xl bg-white p-8 shadow-card ring-1 ring-ink-100">
          <div>
            <div class="flex items-center gap-3">
              <svg viewBox="0 0 48 48" class="h-9 w-9" aria-hidden="true">
                <path fill="#FFC107" d="M43.6 20.5H42V20H24v8h11.3C33.7 32.9 29.3 36 24 36c-6.6 0-12-5.4-12-12s5.4-12 12-12c3.1 0 5.9 1.2 8 3.1l5.7-5.7C34.6 6.1 29.6 4 24 4 12.9 4 4 12.9 4 24s8.9 20 20 20 20-8.9 20-20c0-1.3-.1-2.5-.4-3.5z"/>
                <path fill="#FF3D00" d="M6.3 14.7l6.6 4.8C14.7 16 19 12 24 12c3.1 0 5.9 1.2 8 3.1l5.7-5.7C34.6 6.1 29.6 4 24 4 16.3 4 9.7 8.3 6.3 14.7z"/>
                <path fill="#4CAF50" d="M24 44c5.2 0 10-2 13.6-5.2l-6.3-5.3C29.2 35 26.7 36 24 36c-5.3 0-9.7-3.1-11.3-7.6l-6.5 5C9.5 39.6 16.2 44 24 44z"/>
                <path fill="#1976D2" d="M43.6 20.5H42V20H24v8h11.3c-.8 2.3-2.3 4.2-4 5.5l6.3 5.3C41.4 36 44 30.5 44 24c0-1.3-.1-2.5-.4-3.5z"/>
              </svg>
              <div class="leading-tight">
                <p class="font-display text-lg font-bold text-ink-900">Reviews on Google</p>
                <p class="text-sm text-ink-600">Medilife Superspeciality Hospital</p>
              </div>
            </div>
            <div class="mt-4 flex items-center gap-1 text-accent-500" role="img" aria-label="Rated 5 out of 5 stars">
              {Array.from({ length: 5 }).map(() => <Icon name="star" class="h-6 w-6" />)}
            </div>
            <p class="mt-4 text-[0.98rem] leading-relaxed text-ink-600">
              Patients consistently praise our specialists, clean and well-equipped facilities,
              and compassionate, professional care. See what people are saying on Google.
            </p>
          </div>
          <div class="mt-6 flex flex-col gap-3 sm:flex-row">
            <a href={contact.googleReviewsUrl} target="_blank" rel="noopener" class="btn btn-primary w-full sm:w-auto">
              <Icon name="star" class="h-5 w-5" /> Read Google Reviews
            </a>
            <a href={contact.googleReviewsUrl} target="_blank" rel="noopener" class="btn btn-ghost w-full sm:w-auto">
              <Icon name="plus" class="h-5 w-5" /> Write a Review
            </a>
          </div>
        </div>

        <!-- Featured testimonial(s) -->
        <div class="grid gap-6">
          {testimonials.map((t) => (
            <figure class="flex h-full flex-col rounded-3xl bg-white p-8 shadow-card ring-1 ring-ink-100">
              <Icon name="quote" class="h-10 w-10 text-brand-200" />
              <blockquote class="mt-4 flex-1 font-display text-xl font-medium leading-relaxed text-ink-800">
                {t.text}
              </blockquote>
              <figcaption class="mt-6 flex items-center gap-3 border-t border-ink-100 pt-5">
                <span class="grid h-11 w-11 place-items-center rounded-full bg-brand-100 font-display font-bold text-brand-700">
                  {t.author.charAt(0)}
                </span>
                <span>
                  <span class="block font-bold text-ink-900">{t.author}</span>
                  {t.context && <span class="block text-sm text-ink-600">{t.context}</span>}
                </span>
                <span class="ml-auto flex gap-0.5 text-accent-500" role="img" aria-label="Rated 5 out of 5 stars">
                  {Array.from({ length: 5 }).map(() => <Icon name="star" class="h-4 w-4" />)}
                </span>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    )}
  </div>
</section>

{widget && <script is:inline set:html={reExecScript} />}
