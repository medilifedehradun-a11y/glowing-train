---
import Icon from './Icon.astro';

interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  crumbs?: Crumb[];
}
const { eyebrow, title, subtitle, crumbs = [] } = Astro.props;
const trail: Crumb[] = [{ label: 'Home', href: '/' }, ...crumbs];
---

<section class="relative overflow-hidden bg-gradient-to-br from-brand-800 via-brand-700 to-brand-900">
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="absolute -right-20 -top-24 h-72 w-72 rounded-full bg-white/5"></div>
    <div class="absolute -bottom-24 left-1/3 h-72 w-72 rounded-full bg-white/5"></div>
  </div>
  <div class="container-x relative py-14 lg:py-20">
    <nav aria-label="Breadcrumb">
      <ol class="flex flex-wrap items-center gap-1.5 text-sm text-brand-100/80">
        {trail.map((c, i) => (
          <li class="flex items-center gap-1.5">
            {c.href && i < trail.length - 1 ? (
              <a href={c.href} class="transition hover:text-white">{c.label}</a>
            ) : (
              <span class="text-white">{c.label}</span>
            )}
            {i < trail.length - 1 && <Icon name="chevronRight" class="h-3.5 w-3.5 text-brand-200/60" />}
          </li>
        ))}
      </ol>
    </nav>

    <div class="mt-6 max-w-3xl">
      {eyebrow && (
        <span class="inline-flex items-center gap-2 rounded-full bg-white/10 px-3.5 py-1.5 text-xs font-semibold uppercase tracking-wider text-brand-50">
          {eyebrow}
        </span>
      )}
      <h1 class="mt-4 text-3xl font-extrabold leading-tight text-white sm:text-4xl lg:text-5xl">
        {title}
      </h1>
      {subtitle && (
        <p class="mt-4 text-lg leading-relaxed text-brand-50/90">{subtitle}</p>
      )}
    </div>
  </div>
</section>
