---
import Icon from './Icon.astro';
import { contact } from '../data/site';
import { departments } from '../data/departments';

interface Props {
  heading?: string;
  /** Pre-select a department by slug */
  department?: string;
  class?: string;
}
const { heading, department = '', class: className = '' } = Astro.props;
---

<form
  class:list={['contact-form flex flex-col gap-4', className]}
  action="/api/enquiry"
  method="post"
  data-phone-href={contact.phoneHref}
  data-phone-display={contact.phoneDisplay}
>
  {heading && <h3 class="text-xl font-bold text-ink-900">{heading}</h3>}

  <div class="grid gap-4 sm:grid-cols-2">
    <div class="flex flex-col gap-1.5">
      <label for="cf-first" class="text-sm font-semibold text-ink-700">First name *</label>
      <input id="cf-first" name="first" type="text" required autocomplete="given-name"
        class="rounded-xl border border-ink-200 bg-white px-4 py-3 text-ink-900 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-200" />
    </div>
    <div class="flex flex-col gap-1.5">
      <label for="cf-last" class="text-sm font-semibold text-ink-700">Last name</label>
      <input id="cf-last" name="last" type="text" autocomplete="family-name"
        class="rounded-xl border border-ink-200 bg-white px-4 py-3 text-ink-900 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-200" />
    </div>
  </div>

  <div class="grid gap-4 sm:grid-cols-2">
    <div class="flex flex-col gap-1.5">
      <label for="cf-phone" class="text-sm font-semibold text-ink-700">Phone *</label>
      <input id="cf-phone" name="phone" type="tel" required autocomplete="tel"
        class="rounded-xl border border-ink-200 bg-white px-4 py-3 text-ink-900 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-200" />
    </div>
    <div class="flex flex-col gap-1.5">
      <label for="cf-email" class="text-sm font-semibold text-ink-700">Email</label>
      <input id="cf-email" name="email" type="email" autocomplete="email"
        class="rounded-xl border border-ink-200 bg-white px-4 py-3 text-ink-900 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-200" />
    </div>
  </div>

  <div class="flex flex-col gap-1.5">
    <label for="cf-dept" class="text-sm font-semibold text-ink-700">Department</label>
    <select id="cf-dept" name="department"
      class="rounded-xl border border-ink-200 bg-white px-4 py-3 text-ink-900 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-200">
      <option value="">Select a department (optional)</option>
      {departments.map((d) => (
        <option value={d.name} selected={d.slug === department}>{d.name}</option>
      ))}
      <option value="General Enquiry">General Enquiry</option>
    </select>
  </div>

  <div class="flex flex-col gap-1.5">
    <label for="cf-message" class="text-sm font-semibold text-ink-700">Message</label>
    <textarea id="cf-message" name="message" rows="4"
      placeholder="Tell us briefly how we can help..."
      class="resize-y rounded-xl border border-ink-200 bg-white px-4 py-3 text-ink-900 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-200"></textarea>
  </div>

  {/* Spam honeypot - hidden from real users */}
  <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true" />

  <button type="submit" class="btn btn-primary w-full sm:w-auto">
    <Icon name="mail" class="h-5 w-5" /> <span class="cf-btn-label">Send Enquiry</span>
  </button>

  <p class="cf-status hidden text-sm font-medium" role="status" aria-live="polite"></p>
  <p class="text-xs text-ink-600">
    We will get back to you shortly. Prefer to talk? Call
    <a href={contact.phoneHref} class="font-semibold text-brand-700">{contact.phoneDisplay}</a>
    - we are available 24/7 for emergencies.
  </p>
</form>

<script>
  function initContactForms() {
    document.querySelectorAll<HTMLFormElement>('.contact-form').forEach((form) => {
      if (form.dataset.bound === 'true') return;
      form.dataset.bound = 'true';

      const status = form.querySelector<HTMLParagraphElement>('.cf-status');
      const btn = form.querySelector<HTMLButtonElement>('button[type=submit]');
      const btnLabel = form.querySelector<HTMLSpanElement>('.cf-btn-label');
      const phoneHref = form.dataset.phoneHref || '#';
      const phoneDisplay = form.dataset.phoneDisplay || 'us';

      const setStatus = (html: string, ok: boolean) => {
        if (!status) return;
        status.innerHTML = html;
        status.classList.remove('hidden', 'text-brand-700', 'text-accent-600');
        status.classList.add(ok ? 'text-brand-700' : 'text-accent-600');
      };

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (!form.reportValidity()) return;

        const d = new FormData(form);
        if (d.get('botcheck')) return; // spam bot tripped the honeypot

        const payload = {
          first: d.get('first'), last: d.get('last'), phone: d.get('phone'),
          email: d.get('email'), department: d.get('department'), message: d.get('message'),
        };

        const original = btnLabel?.textContent || 'Send Enquiry';
        if (btn) btn.disabled = true;
        if (btnLabel) btnLabel.textContent = 'Submitting...';
        setStatus('Submitting your enquiry...', true);

        try {
          const res = await fetch('/api/enquiry', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          const data = await res.json().catch(() => ({}));
          if (res.ok && data.ok) {
            form.reset();
            setStatus('Submitted. Thank you - our team will contact you shortly.', true);
          } else {
            throw new Error(data.error || 'failed');
          }
        } catch (err) {
          setStatus(
            'Sorry, we could not submit your enquiry just now. Please call us at ' +
            '<a class="font-semibold underline" href="' + phoneHref + '">' + phoneDisplay + '</a>.',
            false
          );
        } finally {
          if (btn) btn.disabled = false;
          if (btnLabel) btnLabel.textContent = original;
        }
      });
    });
  }
  document.addEventListener('astro:page-load', initContactForms);
</script>
